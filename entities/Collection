{
  "name": "Collection",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Collection name e.g. 'AI Tools for Devs'"
    },
    "description": {
      "type": "string"
    },
    "color": {
      "type": "string",
      "description": "Accent color for the collection",
      "enum": [
        "violet",
        "cyan",
        "pink",
        "emerald",
        "amber",
        "blue"
      ],
      "default": "violet"
    }
  },
  "required": [
    "name"
  ]
}